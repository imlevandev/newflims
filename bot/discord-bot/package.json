{
  "name": "discord-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord bot starter with modular MVC-inspired architecture.",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "register:commands": "tsx src/scripts/register-commands.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^6.0.3",
    "tsx": "^4.20.6",
    "vitest": "^4.0.8"
  }
}
